#!/usr/bin/env python3
from __future__ import annotations

import argparse
import filecmp
import shutil
from pathlib import Path


def repo_root() -> Path:
    return Path(__file__).resolve().parents[3]


def copy_tree(source: Path, target: Path, *, check: bool) -> list[str]:
    messages: list[str] = []
    if not source.is_dir():
        raise SystemExit(f"ERROR: runtime source not found: {source}")

    target.mkdir(parents=True, exist_ok=True)
    source_files = sorted(path for path in source.rglob("*") if path.is_file())
    expected = {path.relative_to(source) for path in source_files}

    for source_file in source_files:
        rel = source_file.relative_to(source)
        target_file = target / rel
        if check:
            if not target_file.exists():
                messages.append(f"missing: {target_file}")
            elif not filecmp.cmp(source_file, target_file, shallow=False):
                messages.append(f"stale: {target_file}")
        else:
            target_file.parent.mkdir(parents=True, exist_ok=True)
            shutil.copy2(source_file, target_file)
            messages.append(f"synced: {target_file}")

    for target_file in sorted(path for path in target.rglob("*") if path.is_file()):
        rel = target_file.relative_to(target)
        if rel not in expected:
            if check:
                messages.append(f"extra: {target_file}")
            else:
                target_file.unlink()
                messages.append(f"removed: {target_file}")

    return messages


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Sync the nx-cad cadnx runtime wrapper into a model directory."
    )
    parser.add_argument(
        "--models-dir",
        type=Path,
        default=repo_root() / "models",
        help="Directory that contains generated NX journals. Defaults to repo models/.",
    )
    parser.add_argument(
        "--check",
        action="store_true",
        help="Check freshness without writing files.",
    )
    args = parser.parse_args()

    root = repo_root()
    source = root / "skills" / "nx-cad" / "cadnx"
    target = args.models_dir.resolve() / "cadnx"
    messages = copy_tree(source, target, check=args.check)

    if args.check:
        if messages:
            print("cadnx runtime is not synchronized:")
            for message in messages:
                print(f"  {message}")
            return 1
        print(f"cadnx runtime is synchronized: {target}")
        return 0

    for message in messages:
        print(message)
    print(f"cadnx runtime ready: {target}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
